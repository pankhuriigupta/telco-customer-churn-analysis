owse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT Contract, Churn, COUNT(*) 
FROM telco_churn_cleaned 
GROUP BY Contract, Churn;
SELECT 
    Contract,
    COUNT(*) AS total_customers,
    SUM(CASE WHEN Churn = 'Yes' THEN 1 ELSE 0 END) AS churned_customers,
    SUM(CASE WHEN Churn = 'Yes' THEN 1 ELSE 0 END) * 100.0 / COUNT(*) AS churn_rate_percent
FROM telco_churn_cleaned
GROUP BY Contract;
SELECT SUM(MonthlyCharges) AS revenue_at_risk
FROM telco_churn_cleaned
WHERE Churn = 'Yes';
SELECT SUM(MonthlyCharges) AS total_revenue
FROM telco_churn_cleaned;
SELECT 
    PaymentMethod,
    COUNT(*) AS total_customers,
    SUM(CASE WHEN Churn = 'Yes' THEN 1 ELSE 0 END) AS churned_customers,
    SUM(CASE WHEN Churn = 'Yes' THEN 1 ELSE 0 END) * 100.0 / COUNT(*) AS churn_rate_percent
FROM telco_churn_cleaned
GROUP BY PaymentMethod;
SELECT 
    InternetService,
    COUNT(*) AS total_customers,
    SUM(CASE WHEN Churn = 'Yes' THEN 1 ELSE 0 END) AS churned_customers,
    SUM(CASE WHEN Churn = 'Yes' THEN 1 ELSE 0 END) * 100.0 / COUNT(*) AS churn_rate_percent
FROM telco_churn_cleaned
GROUP BY InternetService;

</sql><current_tab id="0"/></tab_sql></sqlb_project>
